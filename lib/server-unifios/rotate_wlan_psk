#!/bin/bash
set -e
NEWPSK="${NEWPSK:-$(pwgen 58 1)}"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
SET_PSK_COMMAND="${SET_PSK_COMMAND:-set-unifi-psk}"
PSK_STATE_FILE=${PSK_STATE_FILE:?PSK state file missing}

"$SET_PSK_COMMAND" "$NEWPSK"
umask 077
printf '%s\n' "$NEWPSK" > "$PSK_STATE_FILE"
"$SCRIPT_DIR/render_wlan_psk" "$NEWPSK"
