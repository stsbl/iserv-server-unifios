MkDir 0755 root:root /var/lib/iserv/server-unifios
MkDir 0755 root:root /var/lib/iserv/server-unifios/persistent
MkDir 0755 root:root /var/lib/iserv/server-unifios/data
MkDir 0755 root:root /var/lib/iserv/server-unifios/srv
MkDir 0755 root:root /var/lib/iserv/server-unifios/unifi
MkDir 0755 root:root /var/lib/iserv/server-unifios/mongodb
MkDir 0755 root:root /var/lib/iserv/server-unifios/rabbitmq-ssl
MkDir 0755 root:root /var/lib/iserv/server-unifios/psk
MkDir 0755 root:root /var/log/iserv/server-unifios
MkDir 0750 root:root /etc/iserv/server-unifios
MkDir 0750 root:root /etc/iserv/server-unifios/psk-profiles.d

Touch /var/lib/iserv/server-unifios/docker-compose.env
ChPerm 0600 root:root /var/lib/iserv/server-unifios/docker-compose.env

Test "generate Docker Compose environment"
  . /usr/lib/iserv/cfg
  [ "$(cat /var/lib/iserv/server-unifios/docker-compose.env)" = "HOST=$Host" ]
  ---
  . /usr/lib/iserv/cfg
  printf 'HOST=%s\n' "$Host" > /var/lib/iserv/server-unifios/docker-compose.env

Check /var/lib/iserv/server-unifios/docker-compose.env

Test "create PSK profile directories"
  for profile in /etc/iserv/server-unifios/psk-profiles.d/*.env
  do
    [ -f "$profile" ] || continue
    unset enabled name
    . "$profile"
    [ "${enabled:-false}" = true ] || continue
    case "${name:-}" in
      ''|*[!A-Za-z0-9_-]*) exit 1 ;;
    esac
    [ -d "/var/lib/iserv/server-unifios/psk/$name" ] || exit 1
  done
  ---
  for profile in /etc/iserv/server-unifios/psk-profiles.d/*.env
  do
    [ -f "$profile" ] || continue
    unset enabled name
    . "$profile"
    [ "${enabled:-false}" = true ] || continue
    case "${name:-}" in
      ''|*[!A-Za-z0-9_-]*) exit 1 ;;
    esac
    install -d -m 0755 "/var/lib/iserv/server-unifios/psk/$name"
  done

Start iserv-server-unifios
