MkDir 0755 root:root /var/lib/iserv/server-unifios
MkDir 0755 root:root /var/lib/iserv/server-unifios/psk
MkDir 0700 root:root /var/lib/iserv/server-unifios/psk-state
MkDir 0750 root:root /etc/iserv/server-unifios
MkDir 0750 root:root /etc/iserv/server-unifios/psk-profiles.d

Test "create mutable container directories"
  for dir in \
    /var/lib/iserv/server-unifios/persistent \
    /var/lib/iserv/server-unifios/data \
    /var/lib/iserv/server-unifios/srv \
    /var/lib/iserv/server-unifios/unifi \
    /var/lib/iserv/server-unifios/mongodb \
    /var/lib/iserv/server-unifios/rabbitmq-ssl \
    /var/log/iserv/server-unifios
  do
    [ -d "$dir" ] || exit 1
  done
  ---
  for dir in \
    /var/lib/iserv/server-unifios/persistent \
    /var/lib/iserv/server-unifios/data \
    /var/lib/iserv/server-unifios/srv \
    /var/lib/iserv/server-unifios/unifi \
    /var/lib/iserv/server-unifios/mongodb \
    /var/lib/iserv/server-unifios/rabbitmq-ssl \
    /var/log/iserv/server-unifios
  do
    install -d -m 0755 "$dir"
  done

Touch /var/lib/iserv/server-unifios/docker-compose.env
ChPerm 0600 root:root /var/lib/iserv/server-unifios/docker-compose.env
Check /var/lib/iserv/server-unifios/docker-compose.env

Test "create PSK profile directories"
  for profile in /etc/iserv/server-unifios/psk-profiles.d/*.env
  do
    [ -f "$profile" ] || continue
    unset enabled name
    . "$profile"
    [ "${enabled:-false}" = true ] || continue
    case "${name:-}" in
      ''|*[!A-Za-z0-9_-]*) exit 1 ;;
    esac
    [ -d "/var/lib/iserv/server-unifios/psk/$name" ] || exit 1
  done
  ---
  for profile in /etc/iserv/server-unifios/psk-profiles.d/*.env
  do
    [ -f "$profile" ] || continue
    unset enabled name
    . "$profile"
    [ "${enabled:-false}" = true ] || continue
    case "${name:-}" in
      ''|*[!A-Za-z0-9_-]*) exit 1 ;;
    esac
    install -d -m 0755 "/var/lib/iserv/server-unifios/psk/$name"
  done

Start iserv-server-unifios
