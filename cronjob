# Daily UniFi guest WLAN PSK rotation
#
# Cron format: min hour day month weekday user command
UNIFI_SSID=IServ Guest
SET_PSK_COMMAND=/usr/share/iserv/internal-netmgmt/unifi-set-psk
TARGET_DIR=/var/www/internal-netmgmt
UNIFI_BASE_URL=https://unifi.local
UNIFI_SITE=default
UNIFI_WLAN_NAME=IServ Guest
WIFI_NOTICE_TEXT=Achtung! Der WLAN-Schlüssel wird täglich rotiert.
# Use either API key OR username/password:
# UNIFI_API_KEY=...
# UNIFI_USERNAME=...
# UNIFI_PASSWORD=...
15 3 * * * root /usr/share/iserv/internal-netmgmt/rotate_wlan_psk
