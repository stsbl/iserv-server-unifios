# Copy to /etc/iserv/server-unifios/psk-profiles.d/guest.env and chmod 0600.
enabled=true
name=guest
site=default
wlan_name='wireless Gast'
api_key=
# Alternatively leave api_key empty and configure both username and password.
username=
password=
title='IServ Gast-WLAN-Schlüssel'
notice='The WLAN key is rotated on demand.'
# cidr, group, role, or authenticated
access_mode=cidr
access_value='192.168.100.0/24 fd32:e698:8495::/64'
