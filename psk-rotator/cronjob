# Daily UniFi guest WLAN PSK rotation
#
# Cron format: min hour day month weekday user command
UNIFI_SSID=wireless Gast
SET_PSK_COMMAND=/root/scripts/unifiguestnetworkpskrotator/unifi-set-psk
TARGET_DIR=/var/lib/iserv/server-unifios/psk/guest
UNIFI_BASE_URL=https://unifi.jacobi-hamburg.net
UNIFI_SITE=default
UNIFI_WLAN_NAME=wireless Gast
WIFI_NOTICE_TEXT=Achtung! Der WLAN-Schlüssel wird täglich rotiert. Dieses WLAN-Netzwerk ist ausschließlich für Gäste und andere temporäre Zugänge gedacht.
# Use either API key OR username/password:
UNIFI_API_KEY=
# UNIFI_USERNAME=...
# UNIFI_PASSWORD=...
15 3 * * * root /root/scripts/unifiguestnetworkpskrotator/rotate_wlan_psk
